    "express": "^4.18.2",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mo-context-agent.git"
